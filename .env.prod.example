# =============================================================================
# Reelo PRODUCTION env — TEMPLATE ONLY. Copy to /opt/reelo/.env on the home
# server and fill in the real secrets. NEVER commit the filled-in file.
#
#   docker compose -f docker-compose.prod.yml --env-file /opt/reelo/.env up -d
#
# This file documents every variable docker-compose.prod.yml reads.
# =============================================================================

# ---- Image tag ---------------------------------------------------------------
# The git tag to run (e.g. v1.2.3). The deploy workflow sets this automatically
# to the pushed tag; "latest" here is only a manual-compose fallback.
IMAGE_TAG=latest

# ---- Domain / URLs -----------------------------------------------------------
REELO_BASE_URL=https://api.cognal.xyz
# Browser origin allowed to call the API with credentials (the UI). Comma-sep.
CORS_ORIGINS=https://cognal.xyz
# Where to send the browser after a successful Google login (the UI).
OAUTH_POST_LOGIN_REDIRECT=https://cognal.xyz

# ---- Postgres ----------------------------------------------------------------
POSTGRES_USER=reelo
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=reelo
# Must point at the `postgres` service and match the user/password/db above.
# async driver (asyncpg). Alembic converts to a sync URL itself.
DATABASE_URL=postgresql+asyncpg://reelo:CHANGE_ME_strong_db_password@postgres:5432/reelo

# ---- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---- Crypto / session --------------------------------------------------------
# AES-256-GCM master key (KeyStore). 32 bytes, base64. Generate with:
#   openssl rand -base64 32
REELO_MASTER_KEY=CHANGE_ME_base64_32_bytes
# Signed-cookie session secret. Generate with:
#   openssl rand -base64 32   (or: python -c "import secrets;print(secrets.token_urlsafe(48))")
SESSION_SECRET=CHANGE_ME_session_secret
# Parent domain so the cookie set by api.cognal.xyz is sent to cognal.xyz.
SESSION_COOKIE_DOMAIN=.cognal.xyz

# ---- Google OAuth ------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME
# Must EXACTLY match an Authorized redirect URI in Google Cloud Console.
OAUTH_REDIRECT_URL=https://api.cognal.xyz/auth/callback

# ---- Object storage (MinIO, S3-compatible) -----------------------------------
STORAGE_BACKEND=s3
S3_ENDPOINT=http://minio:9000
S3_BUCKET=reelo-assets
S3_REGION=us-east-1
# These S3 access keys are what the backend uses to talk to MinIO. Simplest is
# to set them equal to the MinIO root credentials below.
S3_ACCESS_KEY=CHANGE_ME_minio_user
S3_SECRET_KEY=CHANGE_ME_minio_password

# ---- MinIO root credentials --------------------------------------------------
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password

# ---- OmniVoice (GPU voice clone) — OPT-IN, started manually with --profile ---
OMNIVOICE_URL=http://omnivoice:8002
# Tag of the GPU image (decoupled from app IMAGE_TAG; built rarely on the host).
OMNIVOICE_TAG=latest
# Optional overrides:
# OMNIVOICE_DEVICE=cuda:0
# OMNIVOICE_MODEL=k2-fsa/OmniVoice
# OMNIVOICE_SAMPLE_RATE=24000
# Set to 1 to run OmniVoice WITHOUT a GPU (returns silence — for testing only).
# OMNIVOICE_MOCK=

# ---- Cloudflare Tunnel -------------------------------------------------------
# Token from Cloudflare Zero Trust > Networks > Tunnels (token-managed tunnel).
TUNNEL_TOKEN=CHANGE_ME_cloudflare_tunnel_token

# ---- UI build arg (informational) --------------------------------------------
# NEXT_PUBLIC_API_BASE is BAKED INTO the reelo-ui image AT BUILD TIME by the
# release workflow (--build-arg NEXT_PUBLIC_API_BASE=https://api.cognal.xyz).
# It is NOT read at runtime; listed here only for reference.
NEXT_PUBLIC_API_BASE=https://api.cognal.xyz
