# =============================================================================
# Reelo backend — environment configuration (copy to .env and fill in)
# Read by config.py via pydantic-settings. Prefix: REELO_  (also accepts the
# unprefixed names below for the common infra vars).
# =============================================================================

# ---- App ---------------------------------------------------------------------
REELO_ENV=dev                       # dev | staging | prod
REELO_DEBUG=true
REELO_BASE_URL=http://localhost:8000
# Comma-separated origins allowed by CORS (the reelo-ui dev server).
REELO_CORS_ORIGINS=http://localhost:3000

# ---- Postgres ----------------------------------------------------------------
# async driver (asyncpg). Alembic env.py converts this to a sync URL itself.
DATABASE_URL=postgresql+asyncpg://reelo:reelo@localhost:5432/reelo

# ---- Redis / Arq -------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---- Master encryption key (KeyStore, AES-256-GCM) ---------------------------
# 32 bytes, base64-encoded. Generate with:
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
REELO_MASTER_KEY=

# ---- Session (signed cookie) -------------------------------------------------
# Any high-entropy string. Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=
SESSION_COOKIE_NAME=reelo_session
SESSION_MAX_AGE=1209600             # seconds (14 days)
# Cross-subdomain cookie (prod only): set to the parent domain so the cookie set
# by api.cognal.xyz is also sent to cognal.xyz. Leave BLANK in dev (host-only).
SESSION_COOKIE_DOMAIN=
# Force the Secure attribute. Blank = derive from REELO_ENV (Secure only in prod).
# In prod (Cloudflare HTTPS) set SESSION_SECURE=true.
SESSION_SECURE=

# ---- Google OAuth ------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match the redirect URI registered in Google Cloud console.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
# Where to send the browser after a successful login (the UI).
OAUTH_POST_LOGIN_REDIRECT=http://localhost:3000

# ---- Object storage ----------------------------------------------------------
# STORAGE_BACKEND: local | s3
STORAGE_BACKEND=local
# local backend: root directory on disk
STORAGE_LOCAL_ROOT=./.reelo-storage
# s3 backend (also works with MinIO / any S3-compatible store)
STORAGE_BUCKET=reelo-assets
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT_URL=                # e.g. http://localhost:9000 for MinIO; blank = AWS
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_SIGNED_URL_TTL=3600          # seconds

# ---- Worker ------------------------------------------------------------------
WORKER_MAX_JOBS=10                   # concurrency per Arq worker

# ---- OmniVoice (voice-clone microservice) ------------------------------------
# Base URL of the Reelo-hosted OmniVoice GPU service (services/omnivoice/).
# Leave blank to disable the voice-clone provider. The model runs on a CUDA GPU
# host; for a no-GPU smoke test run the service with OMNIVOICE_MOCK=1 and point
# this at it. E.g. http://localhost:8002 or http://<gpu-host>:8002.
OMNIVOICE_URL=
