# Copy this file to `.env` and fill in your keys.
# Never commit `.env` to git.

# ElevenLabs — text-to-speech.
# Get from: https://elevenlabs.io  →  Profile  →  API Keys
ELEVENLABS_API_KEY=

# kie.ai — image generation via gpt-image-2-text-to-image.
# Get from: https://kie.ai  →  Dashboard  →  API Keys
KIE_API_KEY=

# Where to save video output folders.
# DEFAULT: <skill-root>/projects/  (each video gets its own subfolder here)
# Override only if you want videos saved outside the skill folder.
# VIDEOS_OUTPUT_DIR=D:\some-other-location\religion-videos
